/*================================
        RESET & GLOBAL
================================*/

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}


html {
    scroll-behavior: smooth;
}


body {
    background: #030308;
    color: white;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
    padding: 30px;
    position: relative;
}


/*================================
        BACKGROUND LIGHTS
================================*/


.bg-purple {
    position: fixed;

    width: 700px;
    height: 700px;

    background: #7b2cff;

    border-radius: 50%;

    filter: blur(250px);

    opacity: .35;

    top: 150px;
    left: 50%;

    transform: translateX(-50%);

    z-index: -5;
}


.bg-blue {
    position: fixed;

    width: 450px;
    height: 450px;

    background: #0066ff;

    border-radius: 50%;

    filter: blur(220px);

    opacity: .18;

    top: -100px;
    right: -100px;

    z-index: -5;
}



/*================================
        GLASS EFFECT SYSTEM
================================*/


.glass {

    background:
        linear-gradient(
            145deg,
            rgba(255,255,255,.08),
            rgba(255,255,255,.02)
        );

    border:
        1px solid rgba(255,255,255,.12);

    backdrop-filter: blur(25px);

    -webkit-backdrop-filter: blur(25px);


    box-shadow:
        inset 0 0 25px rgba(255,255,255,.03),
        0 20px 60px rgba(0,0,0,.5);
}


/*================================
        NAVIGATION BAR
================================*/


.navbar {

    width: 100%;

    height: 80px;

    padding: 0 35px;

    border-radius: 25px;

    display: flex;

    align-items: center;

    justify-content: space-between;

    position: sticky;

    top: 20px;

    z-index: 100;
}


.logo {

    font-size: 28px;

    font-weight: 800;

    letter-spacing: 3px;
}


.logo span {

    color: #8f5cff;

}


.menu {

    display: flex;

    gap: 40px;
}


.menu a {

    color: white;

    text-decoration: none;

    transition: .3s;
}


.menu a:hover {

    color: #8f5cff;

}



/*================================
            BUTTONS
================================*/


.nav-button,
.primary-btn {

    background:
        linear-gradient(
            45deg,
            #7b2cff,
            #9f60ff
        );

    color: white;

    text-decoration: none;

    padding: 14px 28px;

    border-radius: 15px;

    transition: .3s;
}


.nav-button:hover,
.primary-btn:hover {

    box-shadow:
        0 0 30px #7b2cff;

}


.secondary-btn {

    padding: 14px 28px;

    border-radius: 15px;

    text-decoration: none;

    color: white;

    border: 1px solid rgba(255,255,255,.2);

    transition: .3s;
}


.secondary-btn:hover {

    color: #8f5cff;

    border-color: #8f5cff;

}


/*================================
            HERO
================================*/


.hero {

    margin-top: 90px;

    display: grid;

    grid-template-columns: 1.3fr 1fr;

    align-items: center;

    gap: 70px;
}


.hero-tag {

    display: inline-block;

    padding: 12px 22px;

    border-radius: 40px;

    margin-bottom: 25px;
}


.hero-content h1 {

    font-size: 78px;

    line-height: 1.05;

    margin-bottom: 25px;

    text-shadow:
        0 0 30px rgba(255,255,255,.25);
}


.hero-content p {

    color: #aaaaaa;

    max-width: 520px;

    line-height: 1.7;

    font-size: 18px;
}


.hero-buttons {

    margin-top: 40px;

    display: flex;

    gap: 20px;
}


/*================================
        FUTURE PROFILE CARD
================================*/


.profile-card {

    position: relative;

    width: 360px;

    height: 500px;

    justify-self: center;

    border-radius: 35px;

    overflow: hidden;


    background:
        linear-gradient(
            145deg,
            rgba(255,255,255,.08),
            rgba(255,255,255,.02)
        );


    border:
        1px solid rgba(255,255,255,.15);


    backdrop-filter: blur(30px);


    box-shadow:
        inset 0 0 30px rgba(255,255,255,.05),
        0 30px 80px rgba(0,0,0,.8);


    animation:
        floating 6s ease-in-out infinite;
}
